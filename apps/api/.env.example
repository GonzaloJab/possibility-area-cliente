# Sync (psycopg2) URL — used by Alembic + sync seed
DATABASE_URL=postgresql://possibility:possibility@localhost:5432/possibility
# Async (asyncpg) URL — used at runtime by FastAPI
DATABASE_URL_ASYNC=postgresql+asyncpg://possibility:possibility@localhost:5432/possibility

JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

# Comma-separated origins (not JSON). Include 5174 if Vite uses a fallback port.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

PORT=4000
ENV=development
