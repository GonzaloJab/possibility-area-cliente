# Blank in dev = `/api` via Vite proxy to 127.0.0.1:4000.
VITE_API_URL=
# Client-facing app URL (impersonation / “open as client”). Local dev default below.
VITE_CLIENT_URL=http://localhost:5173
#
# Render “possibility-admin” + Custom Domain admin.possibility.es — set as Build Environment (or service env, Render passes them as Docker build args):
#   VITE_API_URL=https://<your-public-api-host>
#   VITE_CLIENT_URL=https://<your-public-client-host>   e.g. https://clientes.possibility.es
# API service must set CORS_ORIGINS to include https://admin.possibility.es (and the client origin).
