# Copy to `local.env` (gitignored). Values here override repo-root `.env`.
# Use this so `.env` can hold Neon / Render-style settings while local dev keeps localhost URLs.

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
# Optional: only if the web app calls the API directly (not via Vite `/api` proxy). Prefer 127.0.0.1 over localhost on Windows.
# VITE_API_URL=http://127.0.0.1:4000

# Optional: force local Postgres instead of whatever is in .env
# DATABASE_URL=postgresql://possibility:possibility@localhost:5432/possibility
# DATABASE_URL_ASYNC=postgresql+asyncpg://possibility:possibility@localhost:5432/possibility
