# ─── Backend (apps/api) — FastAPI ──────────────────────────────────
# Sync URL (psycopg2): used by Alembic migrations + seed script
DATABASE_URL=postgresql://possibility:possibility@localhost:5432/possibility
# Async URL (asyncpg): used at runtime by FastAPI
DATABASE_URL_ASYNC=postgresql+asyncpg://possibility:possibility@localhost:5432/possibility

# Production (Neon) example — replace USER/PASS/HOST after creating a Neon project:
# DATABASE_URL=postgresql://USER:PASS@ep-xxx.eu-central-1.aws.neon.tech/possibility?sslmode=require
# DATABASE_URL_ASYNC=postgresql+asyncpg://USER:PASS@ep-xxx.eu-central-1.aws.neon.tech/possibility?ssl=require

# JWT — generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Cloudflare R2 (S3-compatible) — for invoice PDFs
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=possibility-invoices
R2_PUBLIC_URL=https://pub-xxx.r2.dev

PORT=4000
ENV=development

# ─── Frontend (apps/web) ───────────────────────────────────────────
VITE_API_URL=http://localhost:4000
