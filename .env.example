# ─── Backend (apps/api) — FastAPI ──────────────────────────────────
# Used by: native `npm run dev`, Docker `docker-compose.yml`, Render. Quote values if URLs contain `&`.
# Local overrides: copy `local.env.example` → `local.env` (gitignored) — wins over this file for dev + Docker.
#
# Default below = machine-local Postgres ^(native dev OR host tools^).
# Same `.env` with Neon URLs = Docker Compose + native both talk to Neon ^(recommended one DB^).

DATABASE_URL=postgresql://possibility:possibility@localhost:5432/possibility
DATABASE_URL_ASYNC=postgresql+asyncpg://possibility:possibility@localhost:5432/possibility

# Replace both lines with Neon when using Docker Compose without docker-compose.postgres.yml:
# DATABASE_URL="postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
# DATABASE_URL_ASYNC="postgresql+asyncpg://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?ssl=require"

# JWT — generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

# CORS (comma-separated). Include 127.0.0.1 if you open the app via that host.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
# Production (Render API): every SPA origin the browser uses must be listed, e.g.
# CORS_ORIGINS=https://clientes.possibility.es,https://admin.possibility.es

# Cloudflare R2 (S3-compatible) — for invoice PDFs
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=possibility-invoices
R2_PUBLIC_URL=https://pub-xxx.r2.dev

PORT=4000
ENV=development

# ─── Frontend (apps/web) — not read by Render web Docker build ─────
# Root `.env` is for the API/DB. Client `VITE_API_URL` for production is set on Render (possibility-web), not here.
# Local native dev: leave unset in apps/web/.env to use `/api`, or see apps/web/.env.example.
